<% content_for :title, "Mes favoris" %>

<section class="container py-5" style="margin-top: 100px;">
  <div class="d-flex align-items-baseline mb-5">
    <h2 class="section-heading">Mes chroniques favorites</h2>
    <div class="section-rule"></div>
  </div>

  <% if @favorites.empty? %>
    <div class="text-center py-5">
      <p class="fst-italic mb-4" style="font-family: 'Lora', Georgia, serif; color: var(--warm-gray); font-size: 1.05rem;">
        Vous n'avez encore ajouté aucune chronique à vos favoris.
      </p>
      <%= link_to "Découvrir des chroniques", chronicles_path, class: "btn btn-dark px-4 py-2" %>
    </div>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
      <% @favorites.each do |favorite| %>
        <% chronicle = favorite.chronicle %>
        <div class="col">
          <div class="card-uniform">
            <%= image_tag(chronicle.photo.attached? ? chronicle.photo : "livre.jpeg", alt: chronicle.title) %>
            <div class="card-overlay">
              <h5><%= truncate(chronicle.title, length: 55) %></h5>
              <p><%= chronicle.user.username %></p>
              <p><%= chronicle.created_at.strftime("%d %b %Y") %></p>
            </div>
            <%= link_to chronicle_path(chronicle), class: "stretched-link" %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="text-center">
      <%= link_to "Découvrir d'autres chroniques", chronicles_path, class: "btn btn-outline-dark px-4 py-2" %>
    </div>
  <% end %>
</section>

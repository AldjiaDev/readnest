<% content_for :title, "Librairies" %>
<% content_for :meta_description, "Retrouvez les librairies indépendantes présentes sur Readnest — soutenez le commerce local et découvrez leurs sélections littéraires." %>

<section class="container py-5" style="margin-top: 100px;">
  <div class="d-flex align-items-baseline mb-5">
    <h2 class="section-heading">Librairies</h2>
    <div class="section-rule"></div>
  </div>

  <% if @bookshops.empty? %>
    <p class="text-center fst-italic" style="color: var(--warm-gray);">Aucune librairie inscrite pour le moment.</p>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @bookshops.each do |bookshop| %>
        <div class="col">
          <div class="card-uniform">
            <% if bookshop.user&.avatar&.attached? %>
              <%= image_tag bookshop.user.avatar, alt: bookshop.name %>
            <% elsif bookshop.logo.attached? %>
              <%= image_tag bookshop.logo, alt: bookshop.name %>
            <% else %>
              <%= image_tag "default_avatar.png", alt: bookshop.name %>
            <% end %>
            <div class="card-overlay">
              <h5><%= bookshop.name %></h5>
              <% if bookshop.description.present? %>
                <p><%= truncate(bookshop.description, length: 90) %></p>
              <% end %>
            </div>
            <%= link_to bookshop_path(bookshop), class: "stretched-link", "aria-label": "Voir la librairie #{bookshop.name}" do %><% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

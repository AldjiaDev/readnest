<!DOCTYPE html>
<html lang="fr">
  <head>
      <!-- Title -->
      <title><%= content_for?(:title) ? yield(:title) : "Readnest – Chroniques littéraires, auteur.ice.s, maisons d’édition et librairies" %></title>

      <!-- Description -->
      <meta name="description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Readnest est une plateforme littéraire où les lecteurs découvrent, partagent et aiment des chroniques, maisons d’édition et librairies autour d’eux.' %>">

      <!-- Keywords (SEO support) -->
      <meta name="keywords" content="Readnest, chroniques littéraires, livres, lecture, maisons d’édition, librairies, auteur.ice.s, littérature" />

      <!-- Viewport -->
      <meta name="viewport" content="width=device-width, initial-scale=1" />

      <!-- Security -->
      <%= csrf_meta_tags %>
      <%= csp_meta_tag %>

      <!-- Google Analytics 4 (gtag.js direct) -->
      <!-- Remplace G-4WBHGWJFH9 par une ENV si tu veux, mais ça fonctionne tel quel -->
      <script async src="https://www.googletagmanager.com/gtag/js?id=G-4WBHGWJFH9"></script>
      <script nonce="<%= content_security_policy_nonce %>">
        window.dataLayer = window.dataLayer || [];
        function gtag(){ dataLayer.push(arguments); }

        gtag('js', new Date());

        // On désactive l'auto page_view car on la gère manuellement avec Turbo
        gtag('config', 'G-4WBHGWJFH9', {
          send_page_view: false,
          anonymize_ip: true
        });
      </script>

      <!-- Styles -->
      <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,400;1,700&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,600&display=swap" rel="stylesheet">
      <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="" />
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
      <%= favicon_link_tag 'logo.jpg' %>

      <!-- ✅ PWA manifest & app icons -->
      <link rel="manifest" href="/manifest.webmanifest">
      <meta name="theme-color" content="#111827">

      <!-- iOS / iPadOS -->
      <link rel="apple-touch-icon" href="/icons/icon-192.png">
      <meta name="apple-mobile-web-app-capable" content="yes">
      <meta name="apple-mobile-web-app-status-bar-style" content="default">

      <!-- Canonical URL -->
      <%= tag(:link, rel: "canonical", href: request.original_url) if request.present? %>

      <!-- OpenGraph -->
      <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : 'Readnest – Chroniques littéraires, maisons d’édition et librairies' %>">
      <meta property="og:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Découvrez et partagez vos lectures sur Readnest.' %>">
      <meta property="og:type" content="<%= content_for?(:og_type) ? yield(:og_type) : 'website' %>">
      <meta property="og:url" content="<%= request.original_url %>">
      <meta property="og:image" content="<%= image_url('logo.jpg') %>">
      <meta property="og:site_name" content="Readnest">
      <meta property="og:locale" content="fr_FR">
      <%= yield :extra_meta if content_for?(:extra_meta) %>

      <!-- Twitter Card -->
      <meta name="twitter:card" content="summary_large_image">
      <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : 'Readnest' %>">
      <meta name="twitter:description" content="<%= content_for?(:meta_description) ? yield(:meta_description) : 'Readnest est une plateforme littéraire de chroniques et de découvertes de librairies.' %>">
      <meta name="twitter:image" content="<%= image_url('logo.jpg') %>">

      <!-- Organization JSON-LD (helps Google link your brand to your domain) -->
      <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "Readnest",
        "url": "https://www.readnest.fr",
        "logo": "https://www.readnest.fr/logo.jpg",
        "sameAs": [
          "https://www.instagram.com/readnest",
          "https://www.linkedin.com/company/readnest",
          "https://twitter.com/readnest"
        ],
        "description": "Readnest est une plateforme littéraire pour découvrir, partager et aimer des chroniques, maisons d’édition et librairies autour de soi."
      }
      </script>

      <!-- Meta tags from display_meta_tags gem (if used elsewhere) -->
      <%= display_meta_tags %>
</head>


  <body class="d-flex flex-column min-vh-100">
    <!-- Navbar -->
<nav class="navbar navbar-expand-lg fixed-top" style="background-color: var(--paper); border-bottom: 1px solid var(--rule-color);">
  <div class="container d-flex align-items-center justify-content-between" style="padding-top: 0.6rem; padding-bottom: 0.6rem;">

    <!-- Logo -->
    <%= link_to root_path, class: "navbar-brand" do %>
      <%= image_tag "logo.jpg", alt: "Readnest", style: "height: 60px;" %>
    <% end %>

    <!-- Burger mobile -->
    <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" style="color: var(--ink);">
      <i class="bi bi-list fs-4"></i>
    </button>

    <!-- Liens -->
    <div class="collapse navbar-collapse" id="navbarNav">
      <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-4">
        <li class="nav-item">
          <%= link_to "Chroniques", chronicles_path, class: "nav-link custom-nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Auteur·rice·s", authors_path, class: "nav-link custom-nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Maisons d’édition", publishing_houses_path, class: "nav-link custom-nav-link" %>
        </li>
        <li class="nav-item">
          <%= link_to "Librairies", map_bookshops_path, class: "nav-link custom-nav-link" %>
        </li>
      </ul>

      <!-- Partie droite -->
      <div class="d-flex align-items-center gap-3">
        <% if user_signed_in? %>
          <%= link_to favorites_path, class: "position-relative", title: "Mes favoris", style: "color: var(--ink);" do %>
            <i class="bi bi-bookmark-heart fs-5"></i>
          <% end %>

          <%= link_to notifications_path, class: "position-relative", style: "color: var(--ink);" do %>
            <i class="bi bi-bell fs-5"></i>
            <% unread_count = current_user.received_notifications.unread.count %>
            <% if unread_count.positive? %>
              <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill" style="background-color: var(--burgundy); font-size: 0.6rem;">
                <%= unread_count %>
              </span>
            <% end %>
          <% end %>

          <div class="dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; color: var(--ink);">
              <% if current_user.avatar.attached? %>
                <%= image_tag current_user.avatar, class: "rounded-circle", style: "width: 30px; height: 30px; object-fit: cover; border: 1px solid var(--rule-color);" %>
              <% else %>
                <i class="bi bi-person-circle fs-5"></i>
              <% end %>
              <span><%= current_user.username %></span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end border-0 shadow-sm" style="background-color: var(--cream-card); border: 1px solid var(--rule-color) !important; border-radius: 0.25rem; min-width: 180px;" aria-labelledby="userDropdown">
              <li><%= link_to "Mon profil", user_path(current_user), class: "dropdown-item", style: "font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; color: var(--ink);" %></li>
              <li><%= link_to "Nouvelle chronique", new_chronicle_path, class: "dropdown-item", style: "font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; color: var(--ink);" %></li>
              <li>
                <%= link_to conversations_path, class: "dropdown-item position-relative", style: "font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; color: var(--ink);" do %>
                  Messagerie
                  <% unread_count = Message.where(read: false).where.not(user: current_user).count %>
                  <% if unread_count.positive? %>
                    <span class="badge rounded-pill ms-2" style="background-color: var(--burgundy); font-size: 0.6rem;"><%= unread_count %></span>
                  <% end %>
                <% end %>
              </li>
              <li><hr class="dropdown-divider" style="border-color: var(--rule-color);"></li>
              <li>
                <%= button_to "Se déconnecter", destroy_user_session_path,
                      method: :delete,
                      class: "dropdown-item",
                      style: "font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; color: var(--burgundy);",
                      form: { data: { turbo: false } } %>
              </li>
            </ul>
          </div>

        <% else %>
          <%= link_to "Connexion", new_user_session_path, class: "btn btn-outline-dark px-3" %>
          <%= link_to "S’inscrire", new_user_registration_path, class: "btn btn-dark px-3" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>


  <!-- Flash messages -->
  <div class="container" style="margin-top: 120px; max-width: 800px;">
    <% flash.each do |key, message| %>
      <div class="alert alert-<%= bootstrap_class_for(key) %> alert-dismissible fade show text-center rounded-3 shadow-sm" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
  </div>


    <!-- Contenu principal sans décalage -->
    <main class="flex-grow-1">
      <%= yield %>
    </main>

<footer class="mt-5 py-5" style="background-color: var(--ink); border-top: 2px solid var(--gold);">
  <div class="container">
    <div class="row g-5">

      <!-- Gauche : identité -->
      <div class="col-md-5">
        <%= image_tag "logo.jpg", alt: "Readnest", style: "max-height: 64px;" %>
        <p class="mt-3 fst-italic" style="font-family: ‘Playfair Display’, Georgia, serif; font-size: 1rem; color: rgba(250,246,239,0.65); line-height: 1.7;">
          « Une bibliothèque numérique où chaque chronique est une aventure littéraire. »
        </p>
        <div class="mt-3" style="height: 1px; width: 48px; background-color: var(--gold); opacity: 0.6;"></div>
        <p class="mt-3 small" style="font-family: ‘Lora’, Georgia, serif; color: rgba(250,246,239,0.45);">
          Contact&ensp;—&ensp;<%= mail_to "contact.readnest@gmail.com", "contact.readnest@gmail.com", style: "color: rgba(250,246,239,0.65); text-decoration: none;" %>
        </p>
        <a href="https://www.instagram.com/readnest_fr" target="_blank" rel="noopener"
           aria-label="Instagram Readnest"
           style="color: rgba(250,246,239,0.5); font-size: 1.3rem; transition: color 0.2s ease;"
           onmouseover="this.style.color=’#d4a843’" onmouseout="this.style.color=’rgba(250,246,239,0.5)’">
          <i class="bi bi-instagram"></i>
        </a>
      </div>

      <!-- Droite : navigation -->
      <div class="col-md-7 d-flex justify-content-md-end align-items-start gap-5">

        <div>
          <p class="mb-3" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); opacity: 0.8;">Navigation</p>
          <nav>
            <ul class="list-unstyled mb-0" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; line-height: 2.2;">
              <li><%= link_to "Accueil", root_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Chroniques", chronicles_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Auteur·rice·s", authors_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Maisons d’édition", publishing_houses_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Librairies", map_bookshops_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "À propos", about_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
            </ul>
          </nav>
        </div>

        <div>
          <p class="mb-3" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); opacity: 0.8;">Légal</p>
          <nav>
            <ul class="list-unstyled mb-0" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.875rem; line-height: 2.2;">
              <li><%= link_to "Mentions légales", mentions_legales_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Confidentialité", confidentialite_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "CGU", cgu_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Cookies", cookies_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
              <li><%= link_to "Plan du site", plan_du_site_path, class: "footer-link text-decoration-none", style: "color: rgba(250,246,239,0.6);" %></li>
            </ul>
          </nav>
        </div>

      </div>

    </div>

    <!-- Bas de page -->
    <div class="mt-5 pt-4" style="border-top: 1px solid rgba(212,196,168,0.15);">
      <p class="mb-0 text-center" style="font-family: ‘Lora’, Georgia, serif; font-size: 0.78rem; color: rgba(250,246,239,0.3); letter-spacing: 0.04em;">
        &copy; <%= Time.current.year %> Readnest &mdash; Tous droits réservés.
      </p>
    </div>
  </div>
</footer>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>

     <%= javascript_importmap_tags %>
      <script type="module" nonce="<%= content_security_policy_nonce %>">
        import * as bootstrap from "bootstrap"

        // Réactive les dropdowns après chaque navigation Turbo
        document.addEventListener("turbo:load", () => {
          const triggers = [].slice.call(document.querySelectorAll('[data-bs-toggle="dropdown"]'))
          triggers.forEach(el => new bootstrap.Dropdown(el))
        })

        // Enregistrement du service worker pour la PWA
        if ("serviceWorker" in navigator) {
          window.addEventListener("load", () => {
            navigator.serviceWorker
              .register("/service-worker.js")
              .then((registration) => {
                console.log("ServiceWorker registered:", registration);
              })
              .catch((error) => {
                console.error("ServiceWorker registration failed:", error);
              });
          });
        }
      </script>

      <!-- GA4 page_view sur chaque navigation Turbo -->
      <script nonce="<%= content_security_policy_nonce %>">
        document.addEventListener("turbo:load", function() {
          if (typeof gtag === "function") {
            gtag('event', 'page_view', {
              page_location: window.location.href,
              page_path: window.location.pathname + window.location.search,
              page_title: document.title
            });
          }
        });
      </script>
  </body>
</html>

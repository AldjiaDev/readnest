<%
  label_style = "font-family: 'Lora', Georgia, serif; font-size: 0.78rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--warm-gray); display: block; margin-bottom: 0.5rem;"
  input_style = "font-family: 'Lora', Georgia, serif; border: 1px solid var(--rule-color); border-radius: 0.25rem; background-color: var(--paper); color: var(--ink); padding: 0.65rem 1rem;"
  textarea_style = "font-family: 'Lora', Georgia, serif; border: 1px solid var(--rule-color); border-radius: 0.25rem; background-color: var(--paper); color: var(--ink); padding: 0.75rem 1rem; line-height: 1.75;"
%>

<%= form_with(model: chronicle, local: true, html: { multipart: true }) do |form| %>
  <% if chronicle.errors.any? %>
    <div class="mb-4 p-4" style="background-color: #fdf0f0; border: 1px solid #e8c4c4; border-left: 3px solid var(--burgundy); border-radius: 0.25rem; font-family: 'Lora', Georgia, serif;">
      <p style="font-weight: 600; color: var(--burgundy); margin-bottom: 0.5rem;"><%= pluralize(chronicle.errors.count, "erreur") %> :</p>
      <ul class="mb-0" style="font-size: 0.9rem; color: var(--ink-soft);">
        <% chronicle.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title, "Titre de la chronique", style: label_style %>
    <%= form.text_field :title, class: "form-control", style: input_style %>
  </div>

  <div class="mb-4">
    <%= form.label :summary, "Introduction / Chapô", style: label_style %>
    <%= form.text_area :summary, rows: 3, placeholder: "Quelques lignes résumant votre chronique…", class: "form-control", style: textarea_style %>
  </div>

  <div class="row">
    <div class="col-md-6 mb-4">
      <%= form.label :author, "Auteur·e du livre", style: label_style %>
      <%= form.text_field :author, class: "form-control", style: input_style, id: "book_author_input" %>
    </div>
    <div class="col-md-6 mb-4 position-relative">
      <%= form.label :book_title, "Titre du livre", style: label_style %>
      <%= form.text_field :book_title, class: "form-control", style: input_style, id: "book_title_input", autocomplete: "off" %>
      <ul id="book_suggestions" class="list-group position-absolute w-100 shadow-sm" style="z-index: 1000; display: none; max-height: 220px; overflow-y: auto; border-radius: 0.25rem; border: 1px solid var(--rule-color);"></ul>
    </div>
  </div>

  <div class="mb-4">
    <%= form.label :publisher, "Maison d'édition", style: label_style %>
    <%= form.text_field :publisher, class: "form-control", style: input_style %>
  </div>

  <div class="mb-4">
    <%= form.label :table_of_contents, "Table des matières (facultatif)", style: label_style %>
    <%= form.text_area :table_of_contents, rows: 3, placeholder: "Un élément par ligne (ex : Introduction, Chapitre I…)", class: "form-control", style: textarea_style %>
    <p style="font-family: 'Lora', Georgia, serif; font-size: 0.78rem; color: var(--warm-gray); margin-top: 0.4rem;">Utilisez la touche Entrée pour séparer les entrées.</p>
  </div>

  <div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-1">
      <%= form.label :content, "Contenu de la chronique", style: label_style %>
      <button type="button"
              onclick="insertQuoteSyntax()"
              style="font-family: 'Lora', Georgia, serif; font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; border: 1px solid var(--rule-color); color: var(--ink); background: transparent; padding: 0.25rem 0.75rem; cursor: pointer; border-radius: 0.2rem;">
        + Insérer une citation
      </button>
    </div>
    <p style="font-family: 'Lora', Georgia, serif; font-size: 0.78rem; color: var(--warm-gray); margin-bottom: 0.5rem;">
      Commencez une ligne par <code>&gt; Votre citation…</code> pour la mettre en forme.
    </p>
    <%= form.text_area :content, rows: 14, placeholder: "Rédigez votre chronique ici…", class: "form-control", style: textarea_style, id: "chronicle_content" %>
  </div>

  <div class="mb-4">
    <%= form.label :photo, "Image associée à la chronique", style: label_style %>
    <%= form.file_field :photo, class: "form-control", style: "font-family: 'Lora', Georgia, serif; border: 1px solid var(--rule-color); border-radius: 0.25rem; color: var(--warm-gray);" %>
    <% if chronicle.photo.attached? %>
      <div class="mt-3">
        <p style="font-family: 'Lora', Georgia, serif; font-size: 0.78rem; color: var(--warm-gray);">Image actuelle :</p>
        <%= image_tag chronicle.photo.variant(resize_to_limit: [400, 400]), style: "max-width: 200px; border-radius: 0.25rem; border: 1px solid var(--rule-color);" %>
      </div>
    <% end %>
  </div>

  <div class="mb-5">
    <%= form.label :caption, "Légende de l'image", style: label_style %>
    <%= form.text_field :caption, placeholder: "Ex : Couverture de l'édition 2023", class: "form-control", style: input_style %>
  </div>

  <div class="text-center">
    <%= form.submit "Publier la chronique", class: "btn btn-dark px-5 py-2" %>
  </div>
<% end %>

<script nonce="<%= content_security_policy_nonce %>">
  function insertQuoteSyntax() {
    const field = document.getElementById("chronicle_content");
    if (!field) return;
    const start = field.selectionStart;
    const end = field.selectionEnd;
    const value = field.value;
    const before = value.substring(0, start);
    const selected = value.substring(start, end) || "Votre citation ici";
    const after = value.substring(end);
    const insertion = "> " + selected;
    field.value = before + insertion + "\n\n" + after;
    field.focus();
    const cursorPosition = (before + insertion).length + 2;
    field.selectionStart = field.selectionEnd = cursorPosition;
  }
</script>

<% content_for :title, "Nouvelle chronique" %>

<div style="background-color: var(--paper); margin-top: 86px; padding-bottom: 4rem;">
  <div style="background-color: var(--parchment); border-bottom: 1px solid var(--rule-color); padding: 3rem 0 2.5rem;">
    <div class="container text-center" style="max-width: 680px;">
      <span style="font-family: 'Lora', Georgia, serif; font-size: 0.7rem; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);">Nouvelle chronique</span>
      <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; font-weight: 700; color: var(--ink); margin-top: 0.5rem; font-style: italic;">
        Partagez votre lecture
      </h1>
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.95rem; color: var(--warm-gray); margin-top: 0.75rem;">
        Rédigez votre chronique et partagez-la avec la communauté Readnest.
      </p>
    </div>
  </div>

  <div class="container py-5" style="max-width: 720px;">
    <div style="background-color: var(--cream-card); border: 1px solid var(--rule-color); border-radius: 0.25rem; padding: 2.5rem;">
      <%= render "form", chronicle: @chronicle %>
    </div>

    <div class="text-center mt-4">
      <%= link_to "← Retour aux chroniques", chronicles_path,
          style: "font-family: 'Lora', Georgia, serif; font-size: 0.78rem; letter-spacing: 0.06em; text-transform: uppercase; color: var(--warm-gray); text-decoration: none; border-bottom: 1px solid var(--rule-color); padding-bottom: 1px;" %>
    </div>
  </div>
</div>

<script nonce="<%= content_security_policy_nonce %>">
  function setupBookAutocomplete() {
    const inputTitle = document.querySelector('input[name="chronicle[book_title]"]');
    const inputAuthor = document.querySelector('input[name="chronicle[author]"]');
    if (!inputTitle) return;

    let suggestions = document.getElementById("book_suggestions");
    if (!suggestions) {
      suggestions = document.createElement("ul");
      suggestions.id = "book_suggestions";
      suggestions.className = "list-group position-absolute w-100";
      suggestions.style = "z-index: 1000; display: none; max-height: 220px; overflow-y: auto; border: 1px solid var(--rule-color); border-radius: 0.25rem;";
      inputTitle.parentNode.appendChild(suggestions);
    }

    inputTitle.addEventListener("input", async function () {
      const query = inputTitle.value.trim();
      if (query.length < 3) { suggestions.style.display = "none"; return; }
      try {
        const response = await fetch(`https://openlibrary.org/search.json?title=${encodeURIComponent(query)}`);
        const data = await response.json();
        suggestions.innerHTML = "";
        data.docs.slice(0, 8).forEach(book => {
          const li = document.createElement("li");
          li.className = "list-group-item list-group-item-action";
          li.style = "font-family: 'Lora', Georgia, serif; font-size: 0.875rem; color: var(--ink); background-color: var(--cream-card); border-color: var(--rule-color);";
          const author = book.author_name ? book.author_name[0] : "Auteur inconnu";
          li.textContent = `${book.title} — ${author}`;
          li.addEventListener("click", function () {
            inputTitle.value = book.title;
            if (inputAuthor) inputAuthor.value = author;
            suggestions.style.display = "none";
          });
          suggestions.appendChild(li);
        });
        suggestions.style.display = data.docs.length ? "block" : "none";
      } catch (e) { console.error(e); }
    });

    document.addEventListener("click", function (e) {
      if (!suggestions.contains(e.target) && e.target !== inputTitle) {
        suggestions.style.display = "none";
      }
    });
  }

  document.addEventListener("turbo:load", setupBookAutocomplete);
  document.addEventListener("DOMContentLoaded", setupBookAutocomplete);
</script>

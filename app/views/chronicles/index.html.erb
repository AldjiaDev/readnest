<% content_for :title, "Chroniques" %>
<% content_for :meta_description, "Découvrez toutes les chroniques littéraires partagées par la communauté Readnest — critiques, coups de cœur et analyses de livres." %>

<section class="container py-5" style="margin-top: 100px;">
  <div class="d-flex align-items-baseline mb-5">
    <h2 class="section-heading">Chroniques</h2>
    <div class="section-rule"></div>
  </div>

  <% if @chronicles.empty? %>
    <p class="text-center fst-italic" style="color: var(--warm-gray);">Aucune chronique à afficher pour le moment.</p>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4">
      <% @chronicles.each do |chronicle| %>
        <div class="col">
          <div class="card-uniform">
            <%= image_tag(chronicle.photo.attached? ? chronicle.photo : "livre.jpeg") %>
            <div class="card-overlay">
              <h5><%= truncate(chronicle.title, length: 55) %></h5>
              <p><%= chronicle.user.username %></p>
            </div>
            <%= link_to chronicle_path(chronicle), class: "stretched-link", "aria-label": "Voir la chronique #{chronicle.title}" do %><% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</section>

<style>
/* ============================================================
   HERO — style éditorial littéraire
============================================================ */
.hero-section {
  background-color: var(--parchment);
  border-bottom: 1px solid var(--rule-color);
  margin-top: 86px;
}

.hero-ornament {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  margin-bottom: 1.75rem;
}

.hero-ornament::before,
.hero-ornament::after {
  content: '';
  display: block;
  width: 80px;
  height: 1px;
  background-color: var(--gold);
}

.hero-ornament span {
  color: var(--gold);
  font-size: 1.2rem;
}

.hero-label {
  font-family: 'Lora', Georgia, serif;
  font-size: 0.75rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--gold);
  font-weight: 600;
  display: block;
  margin-bottom: 1rem;
}

.hero-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: clamp(2.4rem, 6vw, 4.2rem);
  font-weight: 900;
  line-height: 1.1;
  letter-spacing: -0.02em;
  color: var(--ink);
  margin-bottom: 0.5rem;
}

.hero-title em {
  font-style: italic;
  color: var(--burgundy);
}

.hero-subtitle {
  font-family: 'Lora', Georgia, serif;
  font-size: clamp(1rem, 2.2vw, 1.2rem);
  line-height: 1.85;
  color: var(--ink-soft);
  max-width: 680px;
  margin: 1.5rem auto 0;
}

.hero-search .form-control {
  background-color: var(--cream-card);
  border: 1px solid var(--rule-color);
  border-right: none;
  border-radius: 0;
  font-family: 'Lora', Georgia, serif;
  font-size: 0.9rem;
  color: var(--ink);
  padding: 0.75rem 1.25rem;
  box-shadow: none;
}

.hero-search .form-control::placeholder {
  color: var(--warm-gray);
}

.hero-search .form-control:focus {
  border-color: var(--gold);
  box-shadow: none;
  background-color: white;
}

.hero-search .btn {
  background-color: var(--ink);
  border: 1px solid var(--ink);
  color: var(--paper);
  border-radius: 0;
  font-family: 'Lora', Georgia, serif;
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.75rem 1.75rem;
  transition: all 0.25s ease;
}

.hero-search .btn:hover {
  background-color: var(--burgundy);
  border-color: var(--burgundy);
}

.hero-cta {
  font-family: 'Lora', Georgia, serif;
  font-size: 0.8rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 1px solid var(--gold);
  padding-bottom: 2px;
  transition: color 0.2s ease, border-color 0.2s ease;
}

.hero-cta:hover {
  color: var(--burgundy);
  border-color: var(--burgundy);
}

/* ============================================================
   SECTIONS
============================================================ */
.alt-section {
  background-color: var(--parchment);
}
</style>

<!-- ============================================================
     HERO
============================================================ -->
<section class="hero-section py-5 text-center">
  <div class="container py-4 py-md-5">

    <div class="hero-ornament">
      <span>❧</span>
    </div>

    <span class="hero-label">La communauté littéraire</span>

    <h1 class="hero-title">
      Découvrez, partagez,<br>
      <em>célébrez les livres</em>
    </h1>

    <p class="hero-subtitle">
      <strong>Readnest</strong> réunit lecteur·ice·s, auteur·ice·s, libraires et maisons d'édition
      autour d'une passion commune — écrire des chroniques, découvrir des voix nouvelles,
      et célébrer ensemble la littérature.
    </p>

    <div class="hero-search d-flex justify-content-center mt-5">
      <%= form_with url: search_path, method: :get, local: true, class: "d-flex", style: "width: min(100%, 620px);" do |form| %>
        <%= form.text_field :query, value: params[:query],
              placeholder: "Chronique, auteur·ice, librairie, maison d'édition…",
              class: "form-control form-control-lg",
              aria: { label: "Rechercher sur Readnest" } %>
        <%= form.submit "Rechercher", class: "btn btn-lg" %>
      <% end %>
    </div>

    <div class="mt-4">
      <%= link_to "Commencer à écrire", new_chronicle_path, class: "hero-cta" %>
    </div>

  </div>
</section>


<!-- ============================================================
     DERNIÈRES CHRONIQUES
============================================================ -->
<section class="container py-5 mt-3">
  <div class="d-flex align-items-baseline mb-5">
    <h2 class="section-heading">Dernières chroniques</h2>
    <div class="section-rule"></div>
  </div>

  <% if @chronicles.empty? %>
    <p class="text-muted text-center fst-italic">Aucune chronique pour le moment.</p>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
      <% @chronicles.each do |chronicle| %>
        <div class="col">
          <div class="card-uniform">
            <%= image_tag(chronicle.photo.attached? ? chronicle.photo : "default_avatar.png") %>
            <div class="card-overlay">
              <h5><%= truncate(chronicle.title, length: 55) %></h5>
              <p>
                <% if chronicle.user.is_publishing_house? && chronicle.user.publishing_house.present? %>
                  <%= chronicle.user.publishing_house.name %>
                <% else %>
                  <%= chronicle.user.username %>
                <% end %>
              </p>
              <p><%= chronicle.created_at.strftime("%d %b %Y") %></p>
            </div>
            <%= link_to chronicle_path(chronicle), class: "stretched-link", "aria-label": "Voir la chronique #{chronicle.title}" do %><% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="text-center">
      <%= link_to "Toutes les chroniques", chronicles_path, class: "btn btn-dark px-5 py-2" %>
    </div>
  <% end %>
</section>


<!-- ============================================================
     AUTEUR·RICE·S
============================================================ -->
<section class="alt-section py-5">
  <div class="container">
    <div class="d-flex align-items-baseline mb-5">
      <h2 class="section-heading">Auteur·rice·s à découvrir</h2>
      <div class="section-rule"></div>
    </div>

    <% if @authors && @authors.any? %>
      <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        <% @authors.each do |author| %>
          <div class="col">
            <div class="card-uniform">
              <% if author.avatar.attached? %>
                <%= image_tag author.avatar, alt: author.username %>
              <% else %>
                <%= image_tag "default_avatar.png", alt: author.username %>
              <% end %>
              <div class="card-overlay">
                <h5><%= author.username %></h5>
                <% if author.bio.present? %>
                  <p><%= truncate(author.bio, length: 90) %></p>
                <% end %>
              </div>
              <%= link_to user_path(author), class: "stretched-link", "aria-label": "Voir le profil de #{author.username}" do %><% end %>
            </div>
          </div>
        <% end %>
      </div>
      <div class="text-center">
        <%= link_to "Tous les auteur·rice·s", authors_path, class: "btn btn-dark px-5 py-2" %>
      </div>
    <% else %>
      <p class="text-muted text-center fst-italic">Aucun·e auteur·rice à afficher pour le moment.</p>
    <% end %>
  </div>
</section>


<!-- ============================================================
     MAISONS D'ÉDITION
============================================================ -->
<section class="container py-5">
  <div class="d-flex align-items-baseline mb-5">
    <h2 class="section-heading">Maisons d'édition</h2>
    <div class="section-rule"></div>
  </div>

  <% if @publishing_houses.empty? %>
    <p class="text-muted text-center fst-italic">Aucune maison d'édition pour le moment.</p>
  <% else %>
    <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
      <% @publishing_houses.each do |house| %>
        <div class="col">
          <div class="card-uniform">
            <% if house.user&.avatar&.attached? %>
              <%= image_tag house.user.avatar, alt: house.name %>
            <% elsif house.logo.attached? %>
              <%= image_tag house.logo, alt: house.name %>
            <% else %>
              <%= image_tag "default_avatar.png", alt: house.name %>
            <% end %>
            <div class="card-overlay">
              <h5><%= house.name %></h5>
              <p><%= truncate(house.description, length: 90) %></p>
            </div>
            <%= link_to publishing_house_path(house), class: "stretched-link", "aria-label": "Voir #{house.name}" do %><% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="text-center">
      <%= link_to "Toutes les maisons d'édition", publishing_houses_path, class: "btn btn-dark px-5 py-2" %>
    </div>
  <% end %>
</section>


<!-- ============================================================
     LIBRAIRIES
============================================================ -->
<section class="alt-section py-5">
  <div class="container">
    <div class="d-flex align-items-baseline mb-5">
      <h2 class="section-heading">Toutes les librairies</h2>
      <div class="section-rule"></div>
    </div>

    <% if @bookshops.empty? %>
      <p class="text-muted text-center fst-italic">Aucune librairie pour le moment.</p>
    <% else %>
      <div class="row row-cols-1 row-cols-md-3 g-4 mb-5">
        <% @bookshops.each do |bookshop| %>
          <div class="col">
            <div class="card-uniform">
              <% if bookshop.user&.avatar&.attached? %>
                <%= image_tag bookshop.user.avatar, alt: bookshop.name %>
              <% elsif bookshop.logo.attached? %>
                <%= image_tag bookshop.logo, alt: bookshop.name %>
              <% else %>
                <%= image_tag "default_avatar.png", alt: bookshop.name %>
              <% end %>
              <div class="card-overlay">
                <h5><%= bookshop.name %></h5>
                <% if bookshop.description.present? %>
                  <p><%= truncate(bookshop.description, length: 90) %></p>
                <% end %>
              </div>
              <%= link_to bookshop_path(bookshop), class: "stretched-link", "aria-label": "Voir #{bookshop.name}" do %><% end %>
            </div>
          </div>
        <% end %>
      </div>
      <div class="text-center">
        <%= link_to "Toutes les librairies", bookshops_path, class: "btn btn-dark px-5 py-2" %>
      </div>
    <% end %>
  </div>
</section>


<!-- ============================================================
     LIBRAIRIES À PROXIMITÉ — bannière éditoriale
============================================================ -->
<section class="container py-5 my-4">
  <div class="d-flex align-items-baseline mb-4">
    <h2 class="section-heading">Librairies à proximité</h2>
    <div class="section-rule"></div>
  </div>

  <div class="row align-items-center">
    <div class="col-md-8">
      <p style="font-family: 'Lora', Georgia, serif; font-size: 1.05rem; line-height: 1.85; color: var(--ink-soft);">
        Que vous soyez en quête d'une perle rare ou d'un coup de cœur inattendu, les librairies
        autour de vous regorgent de trésors à découvrir. Soutenez les librairies indépendantes
        près de chez vous.
      </p>
    </div>
    <div class="col-md-4 text-md-end text-center mt-3 mt-md-0">
      <%= link_to "Librairies autour de moi", map_bookshops_path, class: "btn btn-dark px-4 py-2" %>
    </div>
  </div>
</section>

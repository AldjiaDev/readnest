<% content_for :title, "Modifier mon profil" %>

<section class="container py-5" style="margin-top: 100px; max-width: 680px;">

  <div class="d-flex align-items-baseline mb-5">
    <h1 class="section-heading">Mon profil</h1>
    <div class="section-rule"></div>
  </div>

  <%= form_with model: @user, local: true, html: { multipart: true } do |f| %>

    <% if @user.errors.any? %>
      <div style="border-left: 3px solid var(--burgundy); background: rgba(107,26,42,0.04); padding: 1rem 1.25rem; margin-bottom: 2rem; font-family: 'Lora', Georgia, serif; font-size: 0.875rem; color: var(--burgundy);">
        <strong><%= pluralize(@user.errors.count, "erreur") %> :</strong>
        <ul style="margin: 0.5rem 0 0 1rem; padding: 0;">
          <% @user.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%# ── Avatar ── %>
    <div style="display: flex; align-items: center; gap: 1.5rem; margin-bottom: 2.5rem; padding-bottom: 2rem; border-bottom: 1px solid var(--rule-color);">
      <div style="flex-shrink: 0;">
        <% if @user.avatar.attached? %>
          <%= image_tag url_for(@user.avatar), style: "width: 80px; height: 80px; border-radius: 50%; object-fit: cover; border: 1px solid var(--rule-color);" %>
        <% else %>
          <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--parchment); border: 1px solid var(--rule-color); display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-person" style="font-size: 2rem; color: var(--ink-soft);"></i>
          </div>
        <% end %>
      </div>
      <div style="flex: 1;">
        <p style="font-family: 'Lora', Georgia, serif; font-size: 0.8rem; color: var(--ink-soft); margin-bottom: 0.5rem; font-style: italic;">Photo de profil</p>
        <%= f.file_field :avatar, style: "
          font-family: 'Lora', Georgia, serif;
          font-size: 0.82rem;
          color: var(--ink);
          background: transparent;
          border: 1px solid var(--rule-color);
          padding: 0.4rem 0.75rem;
          border-radius: 2px;
          width: 100%;
          cursor: pointer;
        " %>
      </div>
    </div>

    <%# ── Identité ── %>
    <div style="margin-bottom: 2rem;">
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rule-color); margin-bottom: 1.25rem;">Identité</p>

      <div style="margin-bottom: 1.25rem;">
        <%= f.label :username, "Pseudo", style: "display: block; font-family: 'Lora', Georgia, serif; font-size: 0.8rem; color: var(--ink-soft); font-style: italic; margin-bottom: 0.35rem;" %>
        <%= f.text_field :username, style: "
          width: 100%; padding: 0.6rem 0.75rem;
          font-family: 'Lora', Georgia, serif; font-size: 0.9rem; color: var(--ink);
          background: var(--cream-card);
          border: 1px solid var(--rule-color); border-radius: 2px;
          outline: none;
        ", onfocus: "this.style.borderColor='var(--gold)'", onblur: "this.style.borderColor='var(--rule-color)'" %>
      </div>

      <div>
        <%= f.label :bio, "Présentation", style: "display: block; font-family: 'Lora', Georgia, serif; font-size: 0.8rem; color: var(--ink-soft); font-style: italic; margin-bottom: 0.35rem;" %>
        <%= f.text_area :bio, rows: 4, placeholder: "Parlez-nous un peu de vous…", style: "
          width: 100%; padding: 0.6rem 0.75rem;
          font-family: 'Lora', Georgia, serif; font-size: 0.9rem; color: var(--ink);
          background: var(--cream-card);
          border: 1px solid var(--rule-color); border-radius: 2px;
          outline: none; resize: vertical;
        ", onfocus: "this.style.borderColor='var(--gold)'", onblur: "this.style.borderColor='var(--rule-color)'" %>
      </div>
    </div>

    <div style="border-top: 1px solid var(--rule-color); margin-bottom: 2rem;"></div>

    <%# ── Présence en ligne ── %>
    <div style="margin-bottom: 2rem;">
      <p style="font-family: 'Lora', Georgia, serif; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rule-color); margin-bottom: 1.25rem;">Présence en ligne</p>

      <% [
        { field: :twitter,   label: "Twitter / X",   icon: "bi-twitter-x",   placeholder: "@monprofil" },
        { field: :instagram, label: "Instagram",      icon: "bi-instagram",   placeholder: "@monprofil" },
        { field: :website,   label: "Site personnel", icon: "bi-globe",       placeholder: "https://monsite.com" }
      ].each do |item| %>
        <div style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.75rem;">
          <div style="width: 32px; height: 32px; flex-shrink: 0; display: flex; align-items: center; justify-content: center; border: 1px solid var(--rule-color); border-radius: 2px; background: var(--parchment);">
            <i class="bi <%= item[:icon] %>" style="font-size: 0.85rem; color: var(--ink-soft);"></i>
          </div>
          <div style="flex: 1;">
            <%= f.label item[:field], item[:label], style: "display: none;" %>
            <%= f.text_field item[:field], placeholder: item[:placeholder], style: "
              width: 100%; padding: 0.6rem 0.75rem;
              font-family: 'Lora', Georgia, serif; font-size: 0.88rem; color: var(--ink);
              background: var(--cream-card);
              border: 1px solid var(--rule-color); border-radius: 2px;
              outline: none;
            ", onfocus: "this.style.borderColor='var(--gold)'", onblur: "this.style.borderColor='var(--rule-color)'" %>
          </div>
        </div>
      <% end %>
    </div>

    <%# ── Profil ── %>
    <% if @user.is_author || @user.is_bookshop || @user.is_publishing_house %>
      <div style="border-top: 1px solid var(--rule-color); padding-top: 2rem; margin-bottom: 2rem;">
        <p style="font-family: 'Lora', Georgia, serif; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--rule-color); margin-bottom: 1.25rem;">Type de compte</p>
        <% [
          { field: :is_author,           label: "Auteur·rice" },
          { field: :is_bookshop,         label: "Librairie" },
          { field: :is_publishing_house, label: "Maison d'édition" }
        ].each do |item| %>
          <label style="display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.75rem; cursor: pointer; font-family: 'Lora', Georgia, serif; font-size: 0.88rem; color: var(--ink);">
            <%= f.check_box item[:field], style: "accent-color: var(--gold); width: 15px; height: 15px; cursor: pointer;" %>
            <%= item[:label] %>
          </label>
        <% end %>
      </div>
    <% end %>

    <%# ── Bouton ── %>
    <div style="border-top: 1px solid var(--rule-color); padding-top: 2rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
      <%= link_to "← Retour au profil", user_path(@user), style: "
        font-family: 'Lora', Georgia, serif; font-size: 0.85rem;
        color: var(--ink-soft); text-decoration: none;
      " %>
      <%= f.submit "Enregistrer les modifications", style: "
        font-family: 'Lora', Georgia, serif; font-size: 0.85rem; letter-spacing: 0.04em;
        background: var(--ink); color: var(--cream-card);
        border: none; padding: 0.6rem 1.75rem; border-radius: 2px;
        cursor: pointer;
      ", onmouseover: "this.style.background='var(--gold)'", onmouseout: "this.style.background='var(--ink)'" %>
    </div>

  <% end %>

  <%# ── Zone danger ── %>
  <div style="margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--rule-color);">
    <p style="font-family: 'Lora', Georgia, serif; font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--burgundy); margin-bottom: 1rem;">Zone de danger</p>
    <p style="font-family: 'Lora', Georgia, serif; font-size: 0.82rem; color: var(--ink-soft); margin-bottom: 1.25rem; font-style: italic;">
      La suppression de votre compte est définitive et effacera toutes vos données.
    </p>
    <%= button_to "Supprimer mon compte",
          registration_path(:user),
          method: :delete,
          data: { confirm: "Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible." },
          style: "
            font-family: 'Lora', Georgia, serif; font-size: 0.82rem;
            background: none; border: 1px solid var(--burgundy);
            color: var(--burgundy); padding: 0.5rem 1.25rem;
            border-radius: 2px; cursor: pointer; letter-spacing: 0.03em;
          " %>
  </div>

</section>

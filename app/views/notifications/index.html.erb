<% content_for :title, "Mes notifications" %>
<% content_for :meta_description, "Vos notifications Readnest — likes, commentaires et abonnements." %>

<section class="container py-5" style="margin-top: 100px; max-width: 760px;">

  <div class="d-flex align-items-baseline mb-5">
    <h1 class="section-heading">Notifications</h1>
    <div class="section-rule"></div>
  </div>

  <% if @notifications.any? %>

    <div style="border: 1px solid var(--rule-color); border-radius: 4px; overflow: hidden; background: var(--cream-card);">
      <% @notifications.each_with_index do |notification, i| %>
        <%
          path = case notification.notifiable
                 when Comment then chronicle_path(notification.notifiable.chronicle)
                 else polymorphic_path(notification.notifiable) rescue notifications_path
                 end

          icon = case notification.action
                 when "liked"     then "bi-heart-fill"
                 when "commented" then "bi-chat-left-text-fill"
                 when "followed"  then "bi-person-plus-fill"
                 else "bi-bell-fill"
                 end

          icon_color = case notification.action
                       when "liked"     then "var(--burgundy)"
                       when "commented" then "var(--gold)"
                       when "followed"  then "var(--ink)"
                       else "var(--ink-soft)"
                       end

          action_text = case notification.action
                        when "liked"     then "a aimé votre chronique"
                        when "commented" then "a commenté votre chronique"
                        when "followed"  then "a commencé à vous suivre"
                        else "a effectué une action"
                        end
        %>
        <div style="
          display: flex;
          align-items: flex-start;
          gap: 1rem;
          padding: 1rem 1.25rem;
          border-bottom: <%= i < @notifications.size - 1 ? '1px solid var(--rule-color)' : 'none' %>;
          background: <%= notification.read ? 'transparent' : 'rgba(184, 134, 11, 0.04)' %>;
          border-left: <%= notification.read ? '3px solid transparent' : '3px solid var(--gold)' %>;
        ">
          <!-- Icône -->
          <div style="
            width: 36px; height: 36px; flex-shrink: 0;
            border-radius: 50%;
            background: var(--parchment);
            border: 1px solid var(--rule-color);
            display: flex; align-items: center; justify-content: center;
          ">
            <i class="bi <%= icon %>" style="font-size: 0.8rem; color: <%= icon_color %>;"></i>
          </div>

          <!-- Texte -->
          <div class="flex-grow-1" style="min-width: 0;">
            <p class="mb-1" style="font-family: 'Lora', Georgia, serif; font-size: 0.9rem; color: var(--ink); line-height: 1.5;">
              <%= link_to notification.actor.username, user_path(notification.actor),
                    style: "color: var(--ink); font-weight: 600; text-decoration: none;" %>
              <span style="color: var(--ink-soft);"> <%= action_text %></span>
              <% unless notification.action == "followed" %>
                &nbsp;<%= link_to "→ Voir", path,
                      style: "color: var(--gold); font-size: 0.8rem; font-weight: 600; text-decoration: none; white-space: nowrap;" %>
              <% end %>
            </p>
            <p class="mb-0" style="font-size: 0.75rem; color: var(--rule-color); font-family: 'Lora', Georgia, serif; font-style: italic;">
              il y a <%= time_ago_in_words(notification.created_at) %>
            </p>
          </div>

          <% unless notification.read %>
            <div style="width: 8px; height: 8px; border-radius: 50%; background: var(--gold); flex-shrink: 0; margin-top: 6px;"></div>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- Marquer toutes comme lues -->
    <% if @notifications.any? { |n| !n.read } %>
      <div class="text-center mt-4">
        <%= button_to "Marquer toutes comme lues", mark_as_read_notifications_path,
              method: :patch,
              style: "background: none; border: 1px solid var(--rule-color); color: var(--ink-soft); font-family: 'Lora', Georgia, serif; font-size: 0.85rem; padding: 0.5rem 1.5rem; border-radius: 2px; cursor: pointer; letter-spacing: 0.03em;" %>
      </div>
    <% end %>

  <% else %>
    <div class="text-center py-5" style="color: var(--ink-soft); font-family: 'Lora', Georgia, serif;">
      <i class="bi bi-bell mb-3 d-block" style="font-size: 2rem; color: var(--rule-color);"></i>
      <p class="fst-italic mb-0">Aucune notification pour le moment.</p>
    </div>
  <% end %>

</section>

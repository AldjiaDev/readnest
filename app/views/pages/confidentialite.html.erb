{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Politique de confidentialité – Readnest",
  "url": "https://www.readnest.fr/politique-de-confidentialite",
  "publisher": {
    "@type": "Organization",
    "name": "Readnest",
    "url": "https://www.readnest.fr"
  }
}
</script>

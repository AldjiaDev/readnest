<% content_for :title, "Librairies indépendantes à Marseille : guide des meilleures adresses" %>
<% content_for :meta_description, "Les meilleures librairies indépendantes à Marseille : du Vieux-Port au Cours Julien, découvrez les adresses incontournables pour les lecteurs marseillais." %>

<div class="container pt-5" style="margin-top: 100px; max-width: 900px;">

  <header class="mb-5">
    <p style="font-family: 'Lora', Georgia, serif; font-size: 0.75rem; letter-spacing: 0.15em; text-transform: uppercase; color: var(--gold);">Guide local — Marseille</p>
    <h1 style="font-family: 'Playfair Display', Georgia, serif; font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 900; color: var(--ink); line-height: 1.2;">Librairies indépendantes à Marseille</h1>
    <div style="height: 2px; width: 60px; background-color: var(--gold); margin-top: 1rem; margin-bottom: 1.5rem;"></div>
    <p style="font-family: 'Lora', Georgia, serif; font-size: 1.1rem; line-height: 1.9; color: var(--ink-soft);">
      Marseille, ville de contrastes et de cultures mêlées, abrite une scène littéraire indépendante à son image : vivante, engagée, ouverte sur la Méditerranée et le monde.
    </p>
  </header>

  <section class="mb-5">
    <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: var(--ink); margin-bottom: 1rem;">Marseille et la littérature</h2>
    <p style="font-family: 'Lora', Georgia, serif; line-height: 1.9; color: var(--ink-soft);">
      Depuis Jean-Claude Izzo et sa trilogie Fabio Montale jusqu'aux nouvelles voix qui racontent la ville avec autant d'amour que de lucidité, Marseille inspire les écrivains comme peu d'autres villes le font.
      Ses librairies indépendantes sont le reflet de cette énergie littéraire — souvent engagées, toujours passionnées.
    </p>
  </section>

  <section class="mb-5">
    <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: var(--ink); margin-bottom: 1.5rem;">Les quartiers à explorer</h2>

    <% [
      ["Le Cours Julien et le 6ème", "Le quartier bohème par excellence. On y trouve des librairies de caractère, souvent spécialisées (BD, jeunesse, littérature engagée), nichées entre cafés et galeries d'art."],
      ["Le Vieux-Port et le 1er", "Le cœur historique de Marseille accueille des librairies généralistes où la littérature méditerranéenne et les récits de mer ont une place de choix."],
      ["La Canebière et le centre (1er et 2ème)", "L'axe central de la ville, avec ses librairies accessibles à tous les publics et ses bouquinistes qui recèlent parfois de vraies pépites."],
      ["Noailles et le 1er", "Quartier populaire et multiculturel, Noailles accueille des librairies qui donnent une grande place aux littératures africaines, arabes et du monde."]
    ].each do |quartier, texte| %>
      <div style="margin-bottom: 2rem; padding: 1.5rem; background-color: var(--parchment); border-left: 3px solid var(--gold);">
        <h3 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.1rem; font-weight: 700; color: var(--ink); margin-bottom: 0.5rem;"><%= quartier %></h3>
        <p style="font-family: 'Lora', Georgia, serif; line-height: 1.8; color: var(--ink-soft); margin: 0;"><%= texte %></p>
      </div>
    <% end %>
  </section>

  <blockquote style="border-left: 3px solid var(--gold); padding: 1.5rem 2rem; margin: 2rem 0; background-color: var(--parchment);">
    <p style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.1rem; font-style: italic; color: var(--ink); margin: 0;">
      « Marseille ne se raconte pas — elle se lit. »
    </p>
  </blockquote>

  <section class="mb-5">
    <h2 style="font-family: 'Playfair Display', Georgia, serif; font-size: 1.4rem; font-weight: 700; color: var(--ink); margin-bottom: 1rem;">Les librairies marseillaises sur Readnest</h2>
    <p style="font-family: 'Lora', Georgia, serif; line-height: 1.9; color: var(--ink-soft);">
      Retrouvez les librairies indépendantes marseillaises sur notre carte et découvrez leurs coups de cœur littéraires.
    </p>
    <div class="mt-4">
      <%= link_to "Librairies autour de moi", map_bookshops_path, class: "btn btn-dark px-4 py-2", style: "font-family: 'Lora', Georgia, serif;" %>
    </div>
  </section>

</div>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "Librairies indépendantes à Marseille : guide des meilleures adresses",
  "description": "Guide des librairies indépendantes de Marseille par quartier.",
  "url": "https://www.readnest.fr/librairies-independantes-marseille",
  "about": { "@type": "City", "name": "Marseille", "containedInPlace": { "@type": "Country", "name": "France" } },
  "publisher": { "@type": "Organization", "name": "Readnest", "url": "https://www.readnest.fr" }
}
</script>
